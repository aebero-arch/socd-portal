# Server-side FastAPI address, reachable from the Next.js server.
BACKEND_URL=http://127.0.0.1:8000

# Comma-separated browser origins permitted to call FastAPI directly.
CORS_ORIGINS=http://localhost:3000

# MariaDB database hosted on Synology.
DATABASE_URL=mysql+pymysql://DATABASE_USER:DATABASE_PASSWORD@SYNOLOGY_HOST:3306/socd_portal?charset=utf8mb4

# Generate and keep a long random value private.
JWT_SECRET=replace-with-a-long-random-secret
